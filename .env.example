# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# Ключ API ProxyAPI
PROXYAPI_KEY=sk-...

# Модель OpenAI (по умолчанию gpt-4o)
# OPENAI_MODEL=gpt-4o

# Temperature для генерации (0.0–2.0, по умолчанию 0.7)
# TEMPERATURE=0.7

# Максимум токенов в ответе (по умолчанию 2048)
# MAX_TOKENS=2048

# Размер контекстного окна в сообщениях (по умолчанию 20)
# CONTEXT_LEN_MESSAGES=20

# Путь к SQLite с контекстом (по умолчанию data/context.db)
# DB_PATH=data/context.db
